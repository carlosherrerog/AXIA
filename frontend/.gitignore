# ─── SEGURIDAD (FUNDAMENTAL) ───
# Ignora cualquier archivo .env en cualquier carpeta del proyecto
**/.env
**/.env.local
**/.env*.local
**/.env.development
**/.env.production

# ─── BACKEND (Python/FastAPI) ───
backend/__pycache__/
backend/*.py[cod]
backend/.pytest_cache/
backend/static/
# Ignora la base de datos local para que no subas datos de prueba
backend/*.db
.conda/

# ─── BLOCKCHAIN (Hardhat/Solidity) ───
blockchain/artifacts/
blockchain/cache/
blockchain/node_modules/
# Si usas TypeChain u otros generados:
blockchain/typechain-types/

# ─── FRONTEND (Expo/React Native) ───
frontend/node_modules/
frontend/.expo/
frontend/dist/
frontend/web-build/
frontend/expo-env.d.ts

# ─── GENERAL / SISTEMA ───
**/node_modules/
.DS_Store
*.pem
*.key